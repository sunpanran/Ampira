{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "version": "26.2.13",
  "default_locale": "zh_CN",
  "icons": {
    "16": "extension/icons/icon-16.png",
    "32": "extension/icons/icon-32.png",
    "48": "extension/icons/icon-48.png",
    "128": "extension/icons/icon-128.png"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "action-popup.html",
    "default_icon": {
      "16": "extension/icons/icon-16.png",
      "32": "extension/icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "extension/service-worker.mjs",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "dashboard.html"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "storage"
  ],
  "optional_permissions": [
    "favicon",
    "search"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "incognito": "not_allowed",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'; frame-src 'none'; img-src 'self' data: https: http://localhost:* http://127.0.0.1:*; connect-src https: http://localhost:* http://127.0.0.1:*"
  }
}
